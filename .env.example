# Database
DATABASE_URL="file:./dev.db"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-to-a-random-secret-in-production"

# OpenAI (optional — legacy vibe summaries)
OPENAI_API_KEY=""

# Google Gemini — day planner (intent parse + itinerary build + replan)
GEMINI_API_KEY=""
# Optional: gemini-2.0-flash (default), gemini-1.5-flash, etc.
GEMINI_MODEL="gemini-2.0-flash"

# Curated Prishtina dataset (defaults to data/places_curated.json or data/json.txt)
DATASET_PATH=""

# Google Maps (optional — falls back to OpenStreetMap)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""

# Turso (production on Vercel only — leave empty for local SQLite)
TURSO_DATABASE_URL=""
TURSO_AUTH_TOKEN=""

# Admin verify businesses (optional)
ADMIN_SECRET=""
