# Database
DATABASE_URL="file:./dev.db"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-to-a-random-secret-in-production"

# OpenAI (optional — app uses rule-based recommender without it)
OPENAI_API_KEY=""

# Google Maps (optional — falls back to OpenStreetMap)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""

# Turso (production on Vercel only — leave empty for local SQLite)
TURSO_DATABASE_URL=""
TURSO_AUTH_TOKEN=""
