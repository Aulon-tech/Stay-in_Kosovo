generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Role: USER | BUSINESS
// PlaceCategory: FOOD | CULTURE | NIGHTLIFE | NATURE | SHOPPING | CAFE
// TransportMode: WALK | BUS | TAXI | BIKE

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  password    String
  name        String?
  role        String   @default("USER")
  preferences String?
  createdAt   DateTime @default(now())

  reviews          Review[]
  itineraries      Itinerary[]
  ownedPlaces      Place[]          @relation("PlaceOwner")
  businessProfile  BusinessProfile?
}

model Place {
  id            String   @id @default(cuid())
  googlePlaceId String?  @unique
  curatedSlug   String?  @unique
  name          String
  description   String
  category      String
  vibes         String   // JSON array of vibe tags
  googleTypes   String?  // JSON array
  lat           Float
  lng           Float
  address       String
  city          String   @default("Prishtina")
  priceLevel    Int      @default(2)
  priceLevelRaw String?
  openingHours  String?
  images        String
  website       String?
  phone         String?
  googleMapsUrl String?
  ownerId       String?
  avgRating     Float    @default(0)
  ratingCount   Int      @default(0)
  feelsLike     String?
  isVerified    Boolean  @default(false)
  createdAt     DateTime @default(now())
  datasetId     Int?     // original SQLite row id

  owner           User?            @relation("PlaceOwner", fields: [ownerId], references: [id])
  businessProfile BusinessProfile?
  reviews         Review[]
  events          Event[]
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  placeId   String
  rating    Int
  comment   String?
  vibeTags  String
  photos    String   @default("[]")
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  place Place @relation(fields: [placeId], references: [id], onDelete: Cascade)
}

model Itinerary {
  id        String    @id @default(cuid())
  userId    String
  title     String
  date      DateTime?
  stops     String
  isPublic  Boolean   @default(false)
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Event {
  id          String   @id @default(cuid())
  name        String
  description String
  placeId     String?
  startTime   DateTime
  endTime     DateTime
  category    String
  lat         Float
  lng         Float

  place Place? @relation(fields: [placeId], references: [id])
}

model TransportRoute {
  id          String @id @default(cuid())
  fromLat     Float
  fromLng     Float
  toLat       Float
  toLng       Float
  mode        String
  durationMin Int
  distanceKm  Float
  cost        Float
}

// accountType on User: role USER = individual, BUSINESS = business
model BusinessProfile {
  id                 String   @id @default(cuid())
  userId             String   @unique
  placeId            String?  @unique
  businessName       String
  description        String
  category           String
  ownerName          String?
  contactEmail       String?
  address            String?
  city               String?  @default("Prishtina")
  lat                Float?
  lng                Float?
  arbkNumber         String?
  website            String?
  socialLinks        String?  // JSON { instagram?, facebook?, ... }
  phone              String?
  openingHours       String?  // JSON
  priceRange         String?
  photos             String   @default("[]")
  logo               String?
  services           String   @default("[]")
  tags               String   @default("[]")
  verificationStatus String   @default("pending")
  verified           Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @default(now()) @updatedAt

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  place Place? @relation(fields: [placeId], references: [id], onDelete: SetNull)
}
